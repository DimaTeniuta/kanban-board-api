NODE_ENV=development

APP_PORT=4000
ALLOWED_ORIGIN=http://localhost:3000

# JWT
JWT_SECRET=changeme
JWT_ACCESS_TOKEN_EXPIRATION_TIME=10m
JWT_REFRESH_TOKEN_EXPIRATION_TIME=1d

# Postgres
POSTGRES_USER=root
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kanban-board
POSTGRES_URI=postgresql://root:changeme@localhost:5432/kanban-board

# Redis
REDIS_PASSWORD=changeme
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URI=redis://:changeme@localhost:6379

# For npm run start:dev — only DB containers needed:
#   docker compose up -d postgres redis
#
# For full Docker app — compose overrides POSTGRES_URI/REDIS_URI to postgres/redis hosts
